{
  "name": "@0disoft/openfeature-local-provider",
  "version": "0.12.1",
  "description": "Local OpenFeature provider for JSON/YAML flag snapshots, CLI validation, file reload/watch, typed evaluation, environment overrides, bucketing, replay fixtures, redacted audit events, and lockable rotating file audit sinks.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0disoft/openfeature-local-provider-audit.git",
    "directory": "packages/local-provider"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "openfeature-local-provider": "./bin/openfeature-local-provider.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "bin",
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm,cjs --dts --sourcemap --clean",
    "pack:check": "pnpm run build && publint && attw --pack .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@openfeature/server-sdk": "^1.22.0"
  },
  "devDependencies": {
    "@openfeature/core": "1.11.0",
    "@openfeature/server-sdk": "1.22.0"
  },
  "keywords": [
    "openfeature",
    "feature-flags",
    "provider",
    "local",
    "testing"
  ],
  "dependencies": {
    "yaml": "2.9.0"
  }
}
